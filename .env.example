# Optional. Phase 1 catalog ingestion does NOT need these — Kalshi and
# Polymarket market/event reads are public. Provide them only if you hit
# auth errors or rate limits and want signed Kalshi requests.

# Kalshi API credentials (https://kalshi.com -> account -> API keys)
KALSHI_API_KEY_ID=
# RSA private key, PEM. For multi-line keys prefer a file path via
# KALSHI_API_PRIVATE_KEY_PATH instead of inlining here.
KALSHI_API_PRIVATE_KEY=
KALSHI_API_PRIVATE_KEY_PATH=
